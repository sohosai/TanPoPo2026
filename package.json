{
  "name": "tanpopo2026",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "check": "turbo run check-types",
    "clean": "turbo run clean && rm -rf .turbo",
    "format": "biome format . --write",
    "ci": "bun run check && bun run format",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "lefthook": "^2.1.5",
    "prettier": "^3.8.2",
    "turbo": "^2.9.5",
    "typescript": "6.0.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}